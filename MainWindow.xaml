<Window x:Class="Paleta.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Paleta"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <Color x:Key="blue">#00FFbb</Color>
        <SolidColorBrush x:Key="SCB" Color="#00FFbb"></SolidColorBrush>
        <LinearGradientBrush x:Key="gradient" StartPoint="1,0" EndPoint="0,1">
            <GradientStop Color="Yellow" Offset="2"></GradientStop>
            <GradientStop Color="Gray"></GradientStop>
        </LinearGradientBrush>
    </Window.Resources>
    <StackPanel>
        <Button Background="{StaticResource ResourceKey=SCB}" x:Name="b1" Click="b1_Click">first</Button>
        <Button Background="{StaticResource ResourceKey=gradient}" Height="100" x:Name="b2">second</Button>
    </StackPanel>
</Window>
