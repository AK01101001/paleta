<Window x:Class="Paleta.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Paleta"
        mc:Ignorable="d"
        Title="Wzornik Kolorów" Height="450" Width="800"
        Background="Cornsilk">
    <StackPanel>
        <Rectangle Width="600" Height="100" x:Name="test" Fill="#fff"></Rectangle>
        <TextBlock>Dobierz kolor suwakami i zapisz przyciskiem</TextBlock>
        <StackPanel Orientation="Horizontal">
            <Label>R</Label>
            <Slider Minimum="0" Maximum="255" x:Name="r" ValueChanged="Change" Width="600" Value="255"></Slider>
            <Label x:Name="ro"></Label>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label>G</Label>
            <Slider Minimum="0" Maximum="255" x:Name="g" ValueChanged="Change" Width="600" Value="255"></Slider>
            <Label x:Name="go"></Label>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label>B</Label>
            <Slider Minimum="0" Maximum="255" x:Name="b" ValueChanged="Change" Width="600" Value="255"></Slider>
            <Label x:Name="bo"></Label>
        </StackPanel>

        <Button Background="Peru" Width="200" x:Name="b1" Click="Download">Download</Button>
        <TextBlock Background="#fff" Width="200" x:Name="output">255, 255, 255</TextBlock>
    </StackPanel>
</Window>
